 	// fresh root instead of adopting it (bounds unbounded trace-context reuse).
 	TPReuseThreshold uint32 `yaml:"tp_reuse_threshold" env:"OTEL_EBPF_BPF_TP_REUSE_THRESHOLD"`
 
+	// ShareChat trace-reuse-breaker: 0 disables. When a single TRACE id has been
+	// adopted by more than this many server requests, OBI mints a fresh root
+	// instead of adopting (bounds mesh-cycle mega-traces that rotate parent span
+	// ids). Should be set well above tp_reuse_threshold (e.g. 1024).
+	TraceReuseThreshold uint32 `yaml:"trace_reuse_threshold" env:"OTEL_EBPF_BPF_TRACE_REUSE_THRESHOLD"`
+
 	// Optimizes for getting requests information immediately when request response is seen
 	HighRequestVolume bool `yaml:"high_request_volume" env:"OTEL_EBPF_BPF_HIGH_REQUEST_VOLUME" validate:"boolean"`
 
