diff --git a/bpf/maps/trace_reuse_count.h b/bpf/maps/trace_reuse_count.h
new file mode 100644
index 0000000..a8401ac
--- /dev/null
+++ b/bpf/maps/trace_reuse_count.h
@@ -0,0 +1,16 @@
+#pragma once
+
+#include <bpfcore/vmlinux.h>
+#include <bpfcore/bpf_helpers.h>
+
+// ShareChat trace-reuse-breaker: counts how many server requests have adopted a
+// given incoming TRACE id. Bounds mesh-cycle mega-traces where the trace id
+// circulates between services via individually-legit per-request hops (every
+// hop presents a fresh parent span id, so the per-parent counter never fires).
+// LRU bounds memory and evicts cold trace ids.
+struct {
+    __uint(type, BPF_MAP_TYPE_LRU_HASH);
+    __type(key, u64);   // first 8 bytes of the incoming trace id
+    __type(value, u32); // number of server requests that adopted this trace id
+    __uint(max_entries, 65536);
+} trace_reuse_count SEC(".maps");
