diff --git a/bpf/common/tracing.h b/bpf/common/tracing.h
index 4cead4d..f928ac1 100644
--- a/bpf/common/tracing.h
+++ b/bpf/common/tracing.h
@@ -10,6 +10,7 @@
 
 #include <maps/trace_map.h>
 #include <maps/tp_reuse_count.h>
+#include <maps/trace_reuse_count.h>
 
 #define NANOSECONDS_PER_EPOCH (15LL * 1000000000LL) // 15 seconds
 #define NANOSECONDS_PER_IMM_EPOCH (100000000LL)     // 100 ms
@@ -58,6 +59,32 @@ static __always_inline u8 tp_reuse_should_break(const unsigned char *parent_id)
     return newcnt > tp_reuse_threshold;
 }
 
+// ShareChat trace-reuse-breaker threshold. 0 = disabled. When a single TRACE id
+// has been adopted by more than this many server requests, callers mint a fresh
+// root instead of adopting. Bounds mesh-cycle mega-traces (a trace id circulating
+// between services via individually-legit hops, each with a fresh parent span id,
+// which the per-parent tp_reuse_threshold cannot see). Legit large traces can
+// reach hundreds of spans per service, so set this an order of magnitude above
+// tp_reuse_threshold (e.g. 1024). Set from Go via OTEL_EBPF_BPF_TRACE_REUSE_THRESHOLD.
+volatile const u32 trace_reuse_threshold;
+
+// Returns 1 if this incoming TRACE id has already anchored more than
+// trace_reuse_threshold server requests. Request-count based, not time based.
+static __always_inline u8 trace_reuse_should_break(const unsigned char *trace_id) {
+    if (trace_reuse_threshold == 0) {
+        return 0; // feature disabled
+    }
+    u64 key = 0;
+    __builtin_memcpy(&key, trace_id, sizeof(key)); // first 8 bytes of trace id
+    if (key == 0) {
+        return 0; // invalid/absent trace id — nothing to break
+    }
+    u32 *cnt = bpf_map_lookup_elem(&trace_reuse_count, &key);
+    u32 newcnt = cnt ? (*cnt + 1) : 1;
+    bpf_map_update_elem(&trace_reuse_count, &key, &newcnt, BPF_ANY);
+    return newcnt > trace_reuse_threshold;
+}
+
 #define TRACE_TYPE_SERVER 1
 #define TRACE_TYPE_CLIENT 2
 
