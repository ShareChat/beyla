         set_trace_info_for_connection(&args->pid_conn.conn, TRACE_TYPE_CLIENT, tp_p);
@@ -863,6 +865,9 @@ __obi_continue_protocol_http(struct pt_regs *ctx,
         goto skip_tp;
     }
 
+    bpf_dbg_printk("STITCHDBG cli-MINT-nomatch s=%d d=%d (no sock_msg entry to adopt)",
