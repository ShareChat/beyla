+func (rbf *ringBufForwarder[T]) logPipelineStats(ctx context.Context) {
+	ticker := time.NewTicker(30 * time.Second)
+	defer ticker.Stop()
+	for {
+		select {
+		case <-ticker.C:
+			rbf.logger.Info("ringbuf pipeline stats",
+				"read", rbf.totalRead.Load(),
+				"parsed", rbf.totalParsed.Load(),
+				"ignored", rbf.totalIgnored.Load(),
+				"errors", rbf.totalErrors.Load(),
+				"flushed", rbf.totalFlushed.Load(),
+			)
+		case <-ctx.Done():
+			return
+		}
+	}
+}
+
 func (rbf *ringBufForwarder[T]) storeLastReadAt(t time.Time) {
