 	rbf.items = make([]T, rbf.cfg.BatchLength)
 	rbf.itemsLen = 0
@@ -243,6 +251,7 @@ func (rbf *ringBufForwarder[T]) fillAndDispatch(
 	freeIdx chan int,
 	workIdx chan<- int,
 ) bool {
+	rbf.totalRead.Add(1)
 	if err := eventsReader.ReadInto(&records[i]); err != nil {
 		freeIdx <- i
