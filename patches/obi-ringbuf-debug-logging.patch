 }
 
 // AlreadyForwarded is used in the case when a second tracer tries to set up the
@@ -184,6 +191,7 @@ func (rbf *ringBufForwarder[T]) readAndForwardInner(ctx context.Context, eventsR
 		go rbf.bgFlushOnTimeout(ctx, out)
