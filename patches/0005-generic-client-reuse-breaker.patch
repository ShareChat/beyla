diff --git a/bpf/common/tracing.h b/bpf/common/tracing.h
index bbdfb9f..e506327 100644
--- a/bpf/common/tracing.h
+++ b/bpf/common/tracing.h
@@ -53,12 +53,14 @@ struct {
 
 // Returns true when this adoption would put the parent span id past
 // client_reuse_threshold adopting client spans. Request-count based, not time
-// based.
-static __always_inline u8 client_reuse_should_break(const tp_info_t *parent_tp) {
+// based. Key is the raw first 8 bytes of the parent span id.
+static __always_inline u8 client_reuse_should_break_key(u64 parent_key) {
     if (client_reuse_threshold == 0) {
         return 0;
     }
-    u64 parent_key = *((const u64 *)parent_tp->span_id);
+    if (!parent_key) {
+        return 0; // no parent context - nothing to bound
+    }
     u32 *cnt = bpf_map_lookup_elem(&client_reuse_count, &parent_key);
     if (!cnt) {
         u32 one = 1;
@@ -70,6 +72,12 @@ static __always_inline u8 client_reuse_should_break(const tp_info_t *parent_tp)
     return newcnt > client_reuse_threshold;
 }
 
+// 0004 wrapper: adopting a parent CONTEXT - its span_id becomes the child's
+// parent id (tp_from_parent).
+static __always_inline u8 client_reuse_should_break(const tp_info_t *parent_tp) {
+    return client_reuse_should_break_key(*((const u64 *)parent_tp->span_id));
+}
+
 #define TRACE_TYPE_SERVER 1
 #define TRACE_TYPE_CLIENT 2
 
diff --git a/bpf/generictracer/protocol_http2.h b/bpf/generictracer/protocol_http2.h
index 3096c15..1682cad 100644
--- a/bpf/generictracer/protocol_http2.h
+++ b/bpf/generictracer/protocol_http2.h
@@ -257,6 +257,17 @@ static __always_inline void http2_grpc_start(void *ctx,
         found_tp = 1;
     }
 
+    // 0005: bound how many client streams may adopt one parent span. The
+    // server tp is found by THREAD/connection key; under Go thread
+    // multiplexing every outbound stream in the process can anchor to
+    // whichever server request is live on that thread, welding unrelated
+    // requests' calls into one trace (staging /call-h2-burst: 250 client
+    // spans / 1 live parent). Same counter map as the Go-path 0004.
+    if (found_tp && client_reuse_should_break_key(*((u64 *)tp_p->tp.parent_id))) {
+        bpf_dbg_printk("0005: parent ctx past client reuse threshold, minting fresh");
+        found_tp = 0;
+    }
+
     if (!found_tp) {
         new_trace_id(&tp_p->tp);
         bpf_memset(tp_p->tp.parent_id, 0, sizeof(tp_p->tp.parent_id));
