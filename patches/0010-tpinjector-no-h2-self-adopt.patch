 		"inject_flags":               flags,
 		"g_bpf_debug":                p.cfg.EBPF.BpfDebug,
 		"disable_client_thread_bind": disableClientThreadBind,
+		"disable_h2_tp_adopt":        disableH2TpAdopt,
 	}
 }
 
