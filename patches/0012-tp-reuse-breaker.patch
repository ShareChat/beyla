index 506c17c4..4cead4d4 100644
--- a/bpf/common/tracing.h
+++ b/bpf/common/tracing.h
@@ -9,6 +9,7 @@
 #include <common/trace_util.h>
 
 #include <maps/trace_map.h>
+#include <maps/tp_reuse_count.h>
 
 #define NANOSECONDS_PER_EPOCH (15LL * 1000000000LL) // 15 seconds
 #define NANOSECONDS_PER_IMM_EPOCH (100000000LL)     // 100 ms
@@ -34,6 +35,29 @@ volatile const u32 disable_client_thread_bind;
 // trace instead. Off by default; only affects the Go uprobe tracer.
 volatile const u32 disable_go_stale_parent;
 
+// ShareChat reuse-breaker threshold. 0 = disabled. When an incoming parent span
+// id has been adopted by more than this many server requests, callers mint a
+// fresh root instead of adopting (bounds unbounded trace-context reuse).
+// Set from Go via OTEL_EBPF_BPF_TP_REUSE_THRESHOLD.
+volatile const u32 tp_reuse_threshold;
+
+// Returns 1 if this incoming parent span id has already anchored more than
+// tp_reuse_threshold server requests. Request-count based, not time based.
+static __always_inline u8 tp_reuse_should_break(const unsigned char *parent_id) {
+    if (tp_reuse_threshold == 0) {
+        return 0; // feature disabled
+    }
+    u64 key = 0;
+    __builtin_memcpy(&key, parent_id, sizeof(key)); // first 8 bytes of span id
+    if (key == 0) {
+        return 0; // genuine root (no parent) — nothing to break
+    }
+    u32 *cnt = bpf_map_lookup_elem(&tp_reuse_count, &key);
+    u32 newcnt = cnt ? (*cnt + 1) : 1;
+    bpf_map_update_elem(&tp_reuse_count, &key, &newcnt, BPF_ANY);
+    return newcnt > tp_reuse_threshold;
+}
+
 #define TRACE_TYPE_SERVER 1
 #define TRACE_TYPE_CLIENT 2
 
