         return java_parent;
     }
 
+    // Generic thread/process-bound client parenting. For single-threaded
+    // runtimes (e.g. Node.js with runtime instrumentation disabled) many
+    // multiplexed client streams share one carrier tid and would all adopt the
+    // same server trace here, merging unrelated requests into one unbounded
+    // trace. When disable_client_thread_bind is set we skip this fallback so
+    // such client calls start their own trace. Language-specific parenting
+    // (Go/Python/nginx/puma/Java) above is unaffected.
+    if (disable_client_thread_bind) {
+        return 0;
+    }
