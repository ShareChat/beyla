diff --git a/bpf/common/tracing.h b/bpf/common/tracing.h
index 2469735f..006c22c3 100644
--- a/bpf/common/tracing.h
+++ b/bpf/common/tracing.h
@@ -15,6 +15,16 @@
 
 volatile const u32 disable_black_box_cp;
 
+// When set, disables the thread/process-bound fallback for parenting *client*
+// requests (find_parent_process_trace and the cp_support connection fallback).
+// Single-threaded runtimes (e.g. Node.js with runtime instrumentation disabled)
+// multiplex many unrelated requests onto one carrier tid; without per-request
+// context those client streams all adopt the same server trace, merging into an
+// unbounded "mega-trace". Disabling the thread bind makes such client calls
+// start their own trace instead. Language-agnostic; safe when no thread-per-
+// request native runtime relies on the generic process fallback.
+volatile const u32 disable_client_thread_bind;
+
 #define TRACE_TYPE_SERVER 1
 #define TRACE_TYPE_CLIENT 2
 
diff --git a/pkg/config/ebpf_tracer.go b/pkg/config/ebpf_tracer.go
index bcf631dc..dc4c36ab 100644
--- a/pkg/config/ebpf_tracer.go
+++ b/pkg/config/ebpf_tracer.go
@@ -91,6 +91,13 @@ type EBPFTracer struct {
 	// Disables OBI black-box context propagation. Used for testing purposes only.
 	DisableBlackBoxCP bool `yaml:"disable_black_box_cp" env:"OTEL_EBPF_BPF_DISABLE_BLACK_BOX_CP" validate:"boolean"`
 
+	// Disables the thread/process-bound fallback for parenting client requests.
+	// Prevents single-threaded runtimes (e.g. Node.js with runtime instrumentation
+	// disabled) from merging unrelated multiplexed client streams into one
+	// unbounded trace. Safe when no thread-per-request native runtime relies on
+	// the generic process fallback for client-span parenting.
+	DisableClientThreadBind bool `yaml:"disable_client_thread_bind" env:"OTEL_EBPF_BPF_DISABLE_CLIENT_THREAD_BIND" validate:"boolean"`
+
 	// Optimizes for getting requests information immediately when request response is seen
 	HighRequestVolume bool `yaml:"high_request_volume" env:"OTEL_EBPF_BPF_HIGH_REQUEST_VOLUME" validate:"boolean"`
 
