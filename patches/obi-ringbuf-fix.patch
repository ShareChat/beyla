diff --git a/bpf/common/ringbuf.h b/bpf/common/ringbuf.h
index 7baf44b5..6f97a3b5 100644
--- a/bpf/common/ringbuf.h
+++ b/bpf/common/ringbuf.h
@@ -18,10 +18,19 @@
 // we can share them later if we find is worth not including code per duplicate
 struct {
     __uint(type, BPF_MAP_TYPE_RINGBUF);
-    __uint(max_entries, 1 << 20);
+    __uint(max_entries, 1 << 23);
     __uint(pinning, OBI_PIN_INTERNAL);
 } events SEC(".maps");
 
+// Per-CPU array to count ring buffer reserve failures (drops).
+// Key 0 = total drop count. Userspace reads this to expose as a metric.
+struct {
+    __uint(type, BPF_MAP_TYPE_PERCPU_ARRAY);
+    __uint(max_entries, 1);
+    __type(key, u32);
+    __type(value, u64);
+} ringbuf_drops SEC(".maps");
+
 // To be Injected from the user space during the eBPF program load & initialization
 volatile const u32 wakeup_data_bytes;
 
@@ -31,9 +40,18 @@ volatile const u32 wakeup_data_bytes;
 static __always_inline long get_flags() {
 
     if (!wakeup_data_bytes) {
-        return 0;
+        return BPF_RB_FORCE_WAKEUP;
     }
 
     const u64 sz = bpf_ringbuf_query(&events, BPF_RB_AVAIL_DATA);
     return sz >= wakeup_data_bytes ? BPF_RB_FORCE_WAKEUP : BPF_RB_NO_WAKEUP;
 }
+
+// Call this when bpf_ringbuf_reserve returns NULL to count dropped events.
+static __always_inline void record_ringbuf_drop() {
+    u32 key = 0;
+    u64 *count = bpf_map_lookup_elem(&ringbuf_drops, &key);
+    if (count) {
+        __sync_fetch_and_add(count, 1);
+    }
+}
