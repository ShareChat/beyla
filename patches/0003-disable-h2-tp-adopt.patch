diff --git a/bpf/tpinjector/tpinjector.c b/bpf/tpinjector/tpinjector.c
index 963586d..92ac8bb 100644
--- a/bpf/tpinjector/tpinjector.c
+++ b/bpf/tpinjector/tpinjector.c
@@ -96,6 +96,15 @@ enum {
 volatile const u32 inject_flags =
     k_inject_http_headers | k_inject_tcp_options; // default: both enabled
 
+// 0010: when set, the H2 injector does NOT adopt a traceparent already present in
+// the outgoing HPACK headers. grpc-go caches Beyla's own injected traceparent in
+// the HTTP/2 HPACK dynamic table and replays it (indexed) on subsequent streams;
+// adopting that replayed value merges every multiplexed stream into one trace_id
+// (the network-relevance/ads-dnb mega-trace). Instead we mint a fresh tp per
+// stream. Safe when instrumented apps don't set their own traceparent
+// (exclude_otel_instrumented_services=true), which is our production case.
+volatile const u32 disable_h2_tp_adopt;
+
 // Kind 25 is unassigned per IANA TCP Parameters registry (released 2000-12-18)
 // Better than experimental options (253-254) which must not be shipped as defaults
 enum { k_tcp_option_kind_otel = 25 };
@@ -1419,6 +1428,15 @@ int obi_packet_extender_validate_h2_tp(struct sk_msg_md *msg) {
     }
 
     if (off) {
+        // 0010: the traceparent we just found in the outgoing HPACK is almost
+        // certainly grpc-go replaying Beyla's own injected value from the dynamic
+        // table. Adopting it makes every multiplexed stream share one trace_id.
+        // Skip adoption and mint a fresh tp per stream instead.
+        if (disable_h2_tp_adopt) {
+            bpf_dbg_printk("0010: ignoring HPACK-replayed traceparent, minting fresh per stream");
+            bpf_tail_call_static(msg, &extender_jump_table, k_tail_create_h2_tp);
+            return SK_PASS;
+        }
         init_tp_ctx_parent_tp(t_ctx);
         bpf_memset(tp_p->tp.parent_id, 0, sizeof(tp_p->tp.parent_id));
         const u32 span_id_offset = hpack_start + target + off;
