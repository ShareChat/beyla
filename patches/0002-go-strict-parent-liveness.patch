diff --git a/bpf/gotracer/go_runtime.c b/bpf/gotracer/go_runtime.c
index 4926cd5..2cb9627 100644
--- a/bpf/gotracer/go_runtime.c
+++ b/bpf/gotracer/go_runtime.c
@@ -670,6 +670,16 @@ int obi_uprobe_runtime_casgstatus(struct pt_regs *ctx) {
             return 0;
         }
 
+        break;
+    case g_dead:
+        // 0002: a dead goroutine cannot own a request; its context must not
+        // remain adoptable by the ancestry climb. Only g_dead - NOT default,
+        // which also catches g_waiting (normal blocking, context still live).
+        if (go_strict_parent) {
+            bpf_map_delete_elem(&go_trace_map, &g_key);
+            bpf_map_delete_elem(&ongoing_goroutines, &g_key);
+        }
+        obi_ctx__del(g_pid_tgid);
         break;
     default:
         obi_ctx__del(g_pid_tgid);
