diff --git a/bpf/common/tracing.h b/bpf/common/tracing.h
index 2469735..d6df1a4 100644
--- a/bpf/common/tracing.h
+++ b/bpf/common/tracing.h
@@ -15,6 +15,18 @@
 
 volatile const u32 disable_black_box_cp;
 
+// beya-1-patch / 0002: strict per-request parent resolution for the Go tracer.
+// Trace context (own goroutine entry OR ancestor entry) may only be adopted
+// while that goroutine currently has a LIVE in-flight server invocation
+// (present in ongoing_http_server_requests / ongoing_grpc_server_requests).
+// A goroutine that is not serving anything (Kafka producer/logger goroutine,
+// Temporal poller, connection-serving goroutine between requests, worker pool)
+// cannot donate its stale context - the client call mints a fresh trace
+// instead. Deterministic and timeout-free. Closes the frozen-anchor and
+// self-chain mega-trace classes. 0 = disabled (stock behavior).
+// Set via OTEL_EBPF_BPF_GO_STRICT_PARENT.
+volatile const u32 go_strict_parent;
+
 #define TRACE_TYPE_SERVER 1
 #define TRACE_TYPE_CLIENT 2
 
