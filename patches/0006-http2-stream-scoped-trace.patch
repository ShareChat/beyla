diff --git a/bpf/common/tracing.h b/bpf/common/tracing.h
index 2469735f..00e428f6 100644
--- a/bpf/common/tracing.h
+++ b/bpf/common/tracing.h
@@ -80,6 +80,36 @@ static __always_inline void delete_trace_info_for_connection(connection_info_t *
     bpf_map_delete_elem(&trace_map, &key);
 }
 
+// ShareChat 0006: stream-scoped variants. HTTP/2 multiplexes many independent
+// streams over one connection; keying trace context by connection alone merges
+// them into a single trace. These key by {conn, type, stream_id} so each H2
+// stream carries its own context. stream_id=0 == the connection-scoped behavior.
+static __always_inline tp_info_pid_t *
+trace_info_for_connection_stream(const connection_info_t *conn, u32 type, u32 stream_id) {
+    trace_map_key_t key = {};
+    trace_key_from_conn(&key, conn, type);
+    key.stream_id = stream_id;
+    return (tp_info_pid_t *)bpf_map_lookup_elem(&trace_map, &key);
+}
+
+static __always_inline void set_trace_info_for_connection_stream(const connection_info_t *conn,
+                                                                 u32 type,
+                                                                 u32 stream_id,
+                                                                 const tp_info_pid_t *info) {
+    trace_map_key_t key = {};
+    trace_key_from_conn(&key, conn, type);
+    key.stream_id = stream_id;
+    bpf_map_update_elem(&trace_map, &key, info, BPF_ANY);
+}
+
+static __always_inline void
+delete_trace_info_for_connection_stream(connection_info_t *conn, u32 type, u32 stream_id) {
+    trace_map_key_t key = {};
+    trace_key_from_conn(&key, conn, type);
+    key.stream_id = stream_id;
+    bpf_map_delete_elem(&trace_map, &key);
+}
+
 static __always_inline u64 current_epoch(u64 ts) {
     const u64 temp = ts / NANOSECONDS_PER_EPOCH;
     return temp * NANOSECONDS_PER_EPOCH;
